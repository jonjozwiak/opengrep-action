{
  "name": "opengrep-action",
  "version": "1.0.0",
  "description": "GitHub Action for running OpenGrep static analysis security testing",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "test": "jest --coverage",
    "lint": "eslint src/ __tests__/",
    "format": "prettier --write 'src/**/*.ts' '__tests__/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' '__tests__/**/*.ts'",
    "package": "npm run build",
    "all": "npm run format:check && npm run lint && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonjozwiak/opengrep-action.git"
  },
  "keywords": [
    "github-action",
    "opengrep",
    "sast",
    "security",
    "static-analysis"
  ],
  "author": "jonjozwiak",
  "license": "MIT",
  "dependencies": {
    "@actions/artifact": "^5.0.3",
    "@actions/core": "^2.0.3",
    "@actions/exec": "^2.0.0",
    "@actions/github": "^8.0.1",
    "@actions/io": "^2.0.0",
    "@actions/tool-cache": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.3.0",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.39.3",
    "globals": "^17.3.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.0"
  },
  "overrides": {
    "@actions/artifact": {
      "undici": "^6.23.0",
      "@actions/github": {
        "undici": "^6.23.0"
      }
    },
    "minimatch": "^10.2.1"
  }
}
